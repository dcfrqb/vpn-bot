# ============================================
# Telegram Bot Configuration
# ============================================
BOT_TOKEN=your_bot_token_here
ADMINS=123456789,987654321

# ============================================
# Database Configuration
# ============================================
# Для Docker Compose используйте значения по умолчанию или переопределите:
POSTGRES_DB=crs_vpn
POSTGRES_USER=crs_user
POSTGRES_PASSWORD=crs_pass
POSTGRES_PORT=5432

# Или укажите полный URL (для внешней БД):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# Redis Configuration (optional)
# ============================================
# Для Docker Compose используется значение по умолчанию
# REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ============================================
# YooKassa Payment Configuration
# ============================================
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_API_KEY=your_api_key_here
# Deep Link для возврата после оплаты (замените your_bot_username на имя вашего бота)
YOOKASSA_RETURN_URL=https://t.me/your_bot_username?start=payment_success
YOOKASSA_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Remna API Configuration
# ============================================
REMNA_API_BASE=https://your-remna-api.com
REMNA_API_KEY=your_remna_api_key_here

# ============================================
# No-DB режим (BOT_MODE=no_db)
# ============================================
# PAYREQ_HMAC_SECRET=your-secret-min-16-chars
# REMNAWAVE_DRY_RUN=1  # Только для локального теста без вызова API

# ============================================
# Webhook Configuration (optional)
# ============================================
# Если используете webhook вместо polling, укажите URL:
# Telegram Webhook URL (для получения обновлений от Telegram)
TELEGRAM_WEBHOOK_URL=https://bot.crs-projects.com/webhook

# YooKassa Webhook URL (для получения уведомлений о платежах)
YOOKASSA_WEBHOOK_URL=https://pay.crs-projects.com/webhook/yookassa

# Порт для FastAPI webhook сервера (по умолчанию 8001)
WEBHOOK_API_PORT=8001

