# Пример конфигурации Nginx для pay.crs-projects.com
# Скопируйте в /etc/nginx/sites-available/crs-vpn-bot и адаптируйте
# Для PROD: envsubst < nginx.conf.example > /etc/nginx/sites-available/crs-vpn-bot
#   (если используете переменные ${YOOKASSA_WEBHOOK_SECRET})

server {
    listen 80;
    server_name pay.crs-projects.com;

    access_log /var/log/nginx/crs-vpn-bot-access.log;
    error_log /var/log/nginx/crs-vpn-bot-error.log;

    # Webhook YooKassa → FastAPI (порт 8001)
    location /webhook/yookassa {
        limit_req zone=webhook burst=5 nodelay;
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Прокидываем секрет из env (envsubst при старте nginx)
        proxy_set_header X-Webhook-Secret "${YOOKASSA_WEBHOOK_SECRET}";
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Health для мониторинга (можно ограничить по IP)
    location /health {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location / {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# В http { } добавить:
# limit_req_zone $binary_remote_addr zone=webhook:10m rate=10r/s;

